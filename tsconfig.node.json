{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "./dist-electron",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["electron-vite/node"]
  },
  "include": ["electron/**/*.ts", "electron.vite.config.ts"]
}
